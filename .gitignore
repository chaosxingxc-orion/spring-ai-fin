# Maven
target/
*.jar
*.war
*.ear
*.class
.mvn/wrapper/maven-wrapper.jar

# Gradle (in case any module switches)
build/
.gradle/

# IDE
.idea/
*.iml
*.iws
*.ipr
.vscode/
.project
.classpath
.settings/
.factorypath

# OS
.DS_Store
Thumbs.db
desktop.ini

# Logs + runtime state
*.log
logs/
var/
state/
state-dir/
*.pid

# Environment + secrets — NEVER commit
.env
.env.local
.env.*.local
*.pem
*.key
*.crt
secrets/

# Spring Boot
application-local.yaml
application-local.yml
application-local.properties

# Test artifacts
*.lcov
coverage/
.nyc_output/

# Python sidecar (when adopted)
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/

# Tier C: local source clones (gitignored; SHAs tracked in third_party/MANIFEST.md)
third_party/*/
third_party/**/

# Architecture artifacts
docs/delivery/*.json
docs/verification/*.json
!docs/delivery/.gitkeep
!docs/delivery/*.log
!docs/verification/.gitkeep

# Gate logs:
#   - gate/log/<sha>.json     — delivery-valid evidence; tracked (committed by maintainer)
#   - gate/log/local/         — local-only / failed / dirty-tree / fail-closed runs;
#                               NEVER tracked, never delivery evidence (cycle-4 sec-A3)
gate/log/local/
